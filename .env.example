# oferTASAS Environment Variables

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ofertasas?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# VTEX API
VTEX_TIMEOUT=5000

# Frontend
FRONTEND_URL="http://localhost:3000"

# API
API_PORT=4000

# Admin (for protected endpoints)
ADMIN_API_KEY="change-me-in-production"
