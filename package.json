{
  "name": "ofertasas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @ofertasas/db run generate",
    "db:migrate": "pnpm --filter @ofertasas/db run migrate",
    "db:push": "pnpm --filter @ofertasas/db run push",
    "db:studio": "pnpm --filter @ofertasas/db run studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.8.0",
  "dependencies": {
    "@prisma/client": "^7.7.0"
  }
}
